VITE_API_BASE_URL=http://localhost:4000/api
VITE_MODEL_CDN_URL=http://localhost:4000/models

# EmailJS (emailjs.com) — used to send the sign-up OTP directly from the
# browser, without a backend. Create a free account, an email service, and a
# template with {{to_email}} and {{otp_code}} variables, then fill these in.
# The public key is safe to ship in frontend code by design.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
